# Server Configuration
NODE_ENV=development
PORT=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=1h

# GitHub Configuration (for Excel storage) - Optional
# 1. Create repo: https://github.com/new (e.g., "exam-data")
# 2. Create data/ folder in repo with a .gitkeep file
# 3. Generate token: https://github.com/settings/tokens (Classic, repo scope)
# 4. Fill in values below:
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
GITHUB_OWNER=your-github-username
GITHUB_REPO=exam-data
GITHUB_BRANCH=main

# Excel File Paths (relative to repo root)
EXCEL_PATH=data

# Admin Default Credentials (change after first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# Proctoring Configuration
PROCTOR_VIOLATION_THRESHOLD=5
PROCTOR_AUTO_SUBMIT=false

# SQLite Database Path
SQLITE_DB_PATH=./data/exam.db

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@exam-system.com

# ============================================
# PRODUCTION DEPLOYMENT (Render + Vercel)
# ============================================
# Required on Render:
#   NODE_ENV=production
#   JWT_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
#   ALLOWED_ORIGINS=https://your-app.vercel.app
#   GITHUB_TOKEN=ghp_your_token_here
#
# Required on Vercel (Environment Variables):
#   VITE_API_URL=https://your-render-app.onrender.com/api
# ============================================
