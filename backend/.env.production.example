# Production Environment Configuration Template
# Copy this file to .env.production and fill in actual values

# =====================
# SERVER CONFIGURATION
# =====================
NODE_ENV=production
PORT=5000

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =====================
# SECURITY
# =====================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-character-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=1h
BCRYPT_ROUNDS=12

# =====================
# DATABASE (PostgreSQL for Production)
# =====================
# Recommended: Use managed PostgreSQL (Railway, AWS RDS, DigitalOcean)
DATABASE_URL=postgresql://user:password@host:5432/proctored_exam

# Leave empty for PostgreSQL, only set for SQLite
SQLITE_DB_PATH=

# =====================
# RATE LIMITING
# =====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# =====================
# PROCTORING
# =====================
PROCTOR_VIOLATION_THRESHOLD=5
PROCTOR_AUTO_SUBMIT=true

# =====================
# EMAIL CONFIGURATION
# =====================
# For Gmail: Use App Password, not regular password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Shree Classes <noreply@your-domain.com>

# =====================
# GITHUB BACKUP (Optional)
# =====================
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=exam-data-backup
GITHUB_BRANCH=main

# =====================
# LOGGING
# =====================
LOG_LEVEL=info
LOG_FILE=/var/log/app/backend.log

# =====================
# MONITORING (Optional)
# =====================
ENABLE_METRICS=true
METRICS_PORT=9090

# =====================
# CORS (Additional)
# =====================
# For development, keep these
# For production, only set ALLOWED_ORIGINS above
